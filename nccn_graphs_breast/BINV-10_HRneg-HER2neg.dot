// BINV-10 — Systemic Adjuvant Treatment: HR-Negative / HER2-Negative Disease (TNBC)
digraph BINV10 {
  rankdir=LR; labelloc="t"; label="BINV-10 · Systemic Adjuvant Treatment — HR-Negative / HER2-Negative (TNBC)";
  fontname="Helvetica-Bold"; fontsize=14;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, margin="0.14,0.09"];
  edge [fontname="Helvetica", fontsize=9];

  entry [label="Ductal/NST, Lobular, Mixed, Micropapillary,\nMetaplastic — HR-negative / HER2-negative", fillcolor="#D6EAF8"];

  small [label="pT1, pT2, or pT3;\nand pN0 or pN1mi (≤2 mm)", shape=diamond, fillcolor="#F9E79F"];
  npos [label="pN+ (≥1 ipsilateral\nmetastases >2 mm)", shape=diamond, fillcolor="#F9E79F"];

  pt1a [label="pT1a (≤0.5 cm)", shape=diamond, fillcolor="#FCF3CF"];
  pt1b [label="pT1b (0.6-1.0 cm)", shape=diamond, fillcolor="#FCF3CF"];
  pt1c [label="pT1c-pT3 (>1 cm)", shape=diamond, fillcolor="#FCF3CF"];
  pN0 [label="pN0", shape=diamond, fillcolor="#FCF3CF"];
  pN1mi [label="pN1mi", shape=diamond, fillcolor="#FCF3CF"];

  tx_pN0 [label="No adjuvant therapy", fillcolor="#D5F5E3"];
  tx_mid [label="Consider adjuvant chemotherapy and\nadjuvant olaparib if germline BRCA1/2 PV.\nOlaparib after completion of RT (BINV-I).", fillcolor="#D5F5E3"];
  tx_pt1c [label="Adjuvant chemotherapy (category 1) and\nadjuvant olaparib if germline BRCA1/2 PV.\nOlaparib after completion of RT (BINV-I).", fillcolor="#D5F5E3"];

  rt [label="Adjuvant whole breast RT (BINV-2)\nor PMRT (BINV-3). See BINV-I.\nFollow-up → BINV-17", fillcolor="#FDEBD0", style="rounded,filled,dashed"];

  entry -> small; entry -> npos;
  small -> pt1a; small -> pt1b; small -> pt1c;
  pt1a -> pN0 -> tx_pN0;
  pt1a -> pN1mi -> tx_mid;
  pt1b -> tx_mid;
  pt1c -> tx_pt1c;
  npos -> tx_pt1c;
  tx_pN0 -> rt; tx_mid -> rt; tx_pt1c -> rt;

  note [shape=note, fillcolor="#FEF9E7", fontsize=9, label="In select patients with high-risk features (eg, young with high-grade histology),\nadjuvant chemotherapy may be considered (category 2B). See BINV-L."];
  { rank=sink; note; }
}
