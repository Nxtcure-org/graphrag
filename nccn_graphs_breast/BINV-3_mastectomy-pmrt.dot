// BINV-3 — Locoregional Treatment cT1-3, cN0/cN+, M0: Mastectomy ± PMRT
digraph BINV3 {
  rankdir=LR; labelloc="t"; label="BINV-3 · Locoregional Treatment (cT1-3, cN0/cN+, M0) — Mastectomy ± PMRT";
  fontname="Helvetica-Bold"; fontsize=14;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, margin="0.14,0.09"];
  edge [fontname="Helvetica", fontsize=9];

  surg [label="Nipple-sparing, skin-sparing, or total\nmastectomy with surgical axillary staging\n(category 1) ± reconstruction", fillcolor="#D5F5E3"];

  adj [label="ADJUVANT SYSTEMIC THERAPY\nSee BINV-4 to determine whether adjuvant\nsystemic therapy is indicated.\nRT typically given after systemic therapy.\nSee BINV-I for sequencing.", fillcolor="#FDEBD0", style="rounded,filled,dashed"];

  nodal [label="PATHOLOGIC\nNODAL STATUS", shape=diamond, fillcolor="#F9E79F"];

  neg_small [label="Negative axillary nodes\n(pN0/pN0[i+]) and ≤pT2 (≤5 cm)\nand negative margins", shape=diamond, fillcolor="#FCF3CF"];
  neg_pt3 [label="Negative axillary nodes\nand pT3 (>5 cm)", shape=diamond, fillcolor="#FCF3CF"];
  pos13 [label="1-3 positive\naxillary nodes", shape=diamond, fillcolor="#FCF3CF"];
  pos4 [label="≥4 positive\naxillary nodes", shape=diamond, fillcolor="#FCF3CF"];
  posmargin [label="Any pT/pN with\npositive margins", shape=diamond, fillcolor="#FCF3CF"];

  rt_none [label="No RT", fillcolor="#D5F5E3"];
  rt_pt3 [label="Consider PMRT to chest wall\n± comprehensive RNI (including undissected axilla)", fillcolor="#D5F5E3"];
  rt_13 [label="Strongly consider PMRT to chest wall\n+ comprehensive RNI (including undissected axilla)", fillcolor="#D5F5E3"];
  rt_4 [label="PMRT to chest wall + comprehensive RNI\n(including undissected axilla) (category 1)", fillcolor="#D5F5E3"];
  rt_margin [label="Re-excision to negative margins preferred.\nIf not feasible, strongly consider PMRT to\nchest wall ± comprehensive RNI.", fillcolor="#D5F5E3"];

  fu [label="Follow-up → BINV-17", fillcolor="#FDEBD0", style="rounded,filled,dashed"];

  surg -> adj -> nodal;
  nodal -> neg_small -> rt_none;
  nodal -> neg_pt3 -> rt_pt3;
  nodal -> pos13 -> rt_13;
  nodal -> pos4 -> rt_4;
  nodal -> posmargin -> rt_margin;
  rt_none -> fu; rt_pt3 -> fu; rt_13 -> fu; rt_4 -> fu; rt_margin -> fu;
}
