// COL-4 — pMMR/MSS: Pathologic Stage, Adjuvant Treatment
digraph COL4 {
  rankdir=LR; labelloc="t"; label="COL-4 · pMMR/MSS — Pathologic Stage & Adjuvant Treatment";
  fontname="Helvetica-Bold"; fontsize=14;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, margin="0.14,0.09"];
  edge [fontname="Helvetica", fontsize=9];

  stage [label="PATHOLOGIC STAGE\npMMR/MSS", shape=diamond, fillcolor="#F9E79F"];

  s0 [label="Tis; T1, N0, M0;\nT2, N0, M0", fillcolor="#FCF3CF"];
  s3lo [label="T3, N0, M0\n(no high-risk features)", fillcolor="#FCF3CF"];
  s3hi [label="T3, N0, M0 high risk for\nsystemic recurrence, or\nT4, N0, M0", fillcolor="#FCF3CF"];
  s3a  [label="T1-3, N1\n(low-risk stage III)", fillcolor="#FCF3CF"];
  s3b  [label="T4, N1-2; T Any, N2\n(high-risk stage III)", fillcolor="#FCF3CF"];

  stage -> s0; stage -> s3lo; stage -> s3hi; stage -> s3a; stage -> s3b;

  a0 [label="Observation", fillcolor="#EAECEE"];
  a3lo [label="Observation (preferred)\nor Consider capecitabine (6 mo) or\nfluorouracil/leucovorin (6 mo)", fillcolor="#EAECEE"];
  a3hi [label="Capecitabine (6 mo) or fluorouracil/\nleucovorin (6 mo)\nor FOLFOX (6 mo) or CAPEOX (3 mo)\nor Observation", fillcolor="#EAECEE"];
  a3a [label="Preferred: CAPEOX (3 mo) or\nFOLFOX (3-6 mo)\nOther: capecitabine (6 mo) or\nfluorouracil/leucovorin (6 mo)", fillcolor="#EAECEE"];
  a3b [label="Preferred: CAPEOX (3-6 mo) or\nFOLFOX (6 mo)\nOther: capecitabine (6 mo) or\nfluorouracil/leucovorin (6 mo)", fillcolor="#EAECEE"];

  s0 -> a0; s3lo -> a3lo; s3hi -> a3hi; s3a -> a3a; s3b -> a3b;

  survivorship [label="Discuss/facilitate ≥150 min/wk moderate-\nvigorous physical activity (COL-H)\nand Concurrent surveillance → COL-8", fillcolor="#FDEBD0", style="rounded,filled,dashed"];

  a0 -> survivorship; a3lo -> survivorship; a3hi -> survivorship;
  a3a -> survivorship; a3b -> survivorship;

  note [shape=note, fillcolor="#FEF9E7", fontsize=9, label="Stage II/III: if somatic PI3K pathway alterations, start aspirin (unless\ncontraindicated) 100-162 mg PO daily x3 y after recovery from surgery\n(concurrent with chemo if given). Molecular profiling incl. PI3K alterations\non all stage II/III CRC. See Risk Assessment Stage II (COL-F), Adjuvant (COL-G).\nctDNA is prognostic; not used for de-escalation outside trial."];
  { rank=sink; note; }
}
